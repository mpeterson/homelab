# {{ ansible_managed }}
# Samba configuration — managed by Ansible (nas_samba role)
# Do not edit manually; changes will be overwritten.

[global]
    workgroup = {{ nas_samba_workgroup }}
    security = user

    # Protocol versions
    server min protocol = {{ nas_samba_min_protocol }}
    server max protocol = {{ nas_samba_max_protocol }}

    # Encryption and signing
    smb encrypt = {{ nas_samba_encrypt }}
    server signing = {{ nas_samba_server_signing }}
    client signing = {{ nas_samba_client_signing }}

{% if nas_samba_disable_netbios %}
    # Disable legacy NetBIOS
    disable netbios = yes
    smb ports = 445
{% endif %}

    # ZFS-optimized settings (HA safety)
    strict locking = auto
    kernel oplocks = no

{% if nas_samba_fruit_enabled %}
    # macOS (vfs_fruit) optimizations
    vfs objects = catia fruit streams_xattr
    fruit:metadata = {{ nas_samba_fruit_metadata }}
    fruit:model = {{ nas_samba_fruit_model }}
    fruit:nfs_aces = {{ nas_samba_fruit_nfs_aces }}
    fruit:posix_rename = {{ nas_samba_fruit_posix_rename }}
    fruit:veto_appledouble = {{ nas_samba_fruit_veto_appledouble }}
    fruit:wipe_intentionally_left_blank_rfork = {{ nas_samba_fruit_wipe_blank_rfork }}
    fruit:delete_empty_adfiles = {{ nas_samba_fruit_delete_empty_adfiles }}
{% endif %}

    # Logging
    log file = /var/log/samba/log.%m
    max log size = 1000

{% for share in nas_samba_shares %}
[{{ share.name }}]
    path = {{ share.path }}
{% if share.valid_users is defined %}
    valid users = {{ share.valid_users }}
{% endif %}
    writable = {{ 'yes' if share.writable | default(false) else 'no' }}
    browseable = {{ 'yes' if share.browseable | default(true) else 'no' }}
    create mask = {{ share.create_mask | default('0664') }}
    directory mask = {{ share.directory_mask | default('0775') }}
{% if share.time_machine | default(false) %}
    fruit:time machine = yes
{% if share.time_machine_max_size is defined %}
    fruit:time machine max size = {{ share.time_machine_max_size }}
{% endif %}
{% endif %}

{% endfor %}
