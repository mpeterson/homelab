{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Group Velero Helm chart and plugins into a single PR",
      matchFileNames: ["kubernetes/infra/velero/**"],
      groupName: "velero",
    },
    {
      description: "Group Velero CLI (mise) with Velero deployment",
      matchDepNames: ["aqua:vmware-tanzu/velero"],
      groupName: "velero",
    },
    {
      description: "Group kube-prometheus-stack and its CRDs into a single PR",
      matchFileNames: ["kubernetes/infra/prometheus-operator/**"],
      groupName: "kube-prometheus-stack",
    },
    {
      description: "Group democratic-csi NFS, iSCSI, and snapshot-controller into a single PR",
      matchFileNames: ["kubernetes/infra/democratic-csi/**"],
      groupName: "democratic-csi",
    },
    {
      description: "Group qbittorrent, tqm, and qbrr into a single PR",
      matchFileNames: ["kubernetes/apps/qbittorrent/**"],
      groupName: "qbittorrent",
    },
    {
      description: "Group paperless and its valkey dependency into a single PR",
      matchFileNames: ["kubernetes/apps/paperless/**"],
      groupName: "paperless",
    },
    {
      description: "Group ArgoCD server and KSOPS into a single PR",
      matchFileNames: ["kubernetes/bootstrap/argocd/**"],
      groupName: "argocd",
    },
    {
      description: "Group ArgoCD CLI (mise) with ArgoCD deployment",
      matchDepNames: ["aqua:argoproj/argo-cd"],
      groupName: "argocd",
    },
    {
      description: "Group Cilium Helm chart, configs, and bootstrap into a single PR",
      matchFileNames: ["kubernetes/infra/cilium/**"],
      groupName: "cilium",
    },
    {
      description: "Group Cilium bootstrap chart version with Cilium deployment",
      matchPackageNames: ["cilium"],
      groupName: "cilium",
    },
    {
      description: "Group Cilium CLI (mise) with Cilium deployment",
      matchDepNames: ["aqua:cilium/cilium-cli"],
      groupName: "cilium",
    },
    {
      description: "Group Gateway API CRDs with Cilium — CRDs must be updated before or with Cilium",
      matchPackageNames: ["kubernetes-sigs/gateway-api"],
      groupName: "cilium",
    },
    {
      description: "Group Kustomize (mise) with ArgoCD — must match ArgoCD bundled version",
      matchDepNames: ["aqua:kubernetes-sigs/kustomize"],
      groupName: "argocd",
    },
    {
      description: "Group Helm (mise) with ArgoCD — should stay close to ArgoCD bundled version",
      matchDepNames: ["aqua:helm/helm"],
      groupName: "argocd",
    },
    {
      description: "Group kubectl (mise) with Talos — kubectl version tied to K8s version from Talos",
      matchDepNames: ["aqua:kubernetes/kubectl"],
      groupName: "talos",
    },
    {
      description: "Group Talos CLI (mise) into talos group",
      matchDepNames: ["aqua:siderolabs/talos"],
      groupName: "talos",
    },
    {
      description: "Group SOPS CLI (mise) with KSOPS",
      matchDepNames: ["aqua:getsops/sops"],
      groupName: "sops",
    },
    {
      description: "Group KSOPS with SOPS",
      matchPackageNames: ["viaduct-ai/kustomize-sops"],
      groupName: "sops",
    },
  ],
}
