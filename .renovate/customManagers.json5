{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      customType: "regex",
      description: "Track KSOPS version in ArgoCD repo-server patch",
      managerFilePatterns: [
        "/kubernetes/bootstrap/argocd/patches/argocd-repo-server-ksops\\.yaml$/",
      ],
      matchStrings: [
        "# renovate: datasource=github-releases depName=(?<depName>[^\\s]+)\\s+KSOPS_VERSION=\"(?<currentValue>v[^\"]+)\"",
      ],
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      description: "Track argocd-diff-preview Docker image in ArgoCD mod",
      managerFilePatterns: [
        "/kubernetes/bootstrap/argocd/mod\\.just$/",
      ],
      matchStrings: [
        "# renovate: datasource=docker depName=(?<depName>[^\\s]+)\\n_argocd_diff_preview_version := \"(?<currentValue>[^@\"]+)(?:@(?<currentDigest>sha256:[^\"]+))?\"",
      ],
      autoReplaceStringTemplate: "# renovate: datasource=docker depName={{{depName}}}\n_argocd_diff_preview_version := \"{{{newValue}}}@{{{newDigest}}}\"",
      datasourceTemplate: "docker",
    },
    {
      customType: "regex",
      description: "Track ArgoCD Helm chart version for diff preview",
      managerFilePatterns: [
        "/kubernetes/bootstrap/argocd/mod\\.just$/",
      ],
      matchStrings: [
        "# renovate: datasource=helm registryUrl=(?<registryUrl>[^\\s]+) depName=(?<depName>[^\\s]+)\\n_argocd_chart_version := \"(?<currentValue>[^\"]+)\"",
      ],
      datasourceTemplate: "helm",
    },
    {
      customType: "regex",
      description: "Track Cilium Helm chart version in bootstrap mod",
      managerFilePatterns: [
        "/kubernetes/bootstrap/mod\\.just$/",
      ],
      matchStrings: [
        "# renovate: datasource=helm registryUrl=(?<registryUrl>[^\\s]+) depName=(?<depName>[^\\s]+)\\n_cilium_chart_version := \"(?<currentValue>[^\"]+)\"",
      ],
      datasourceTemplate: "helm",
    },
    {
      customType: "regex",
      description: "Track Gateway API CRD versions in kustomization",
      managerFilePatterns: [
        "/kubernetes/infra/gateway-api/kustomization\\.yaml$/",
      ],
      matchStrings: [
        "# renovate: datasource=github-releases depName=(?<depName>[^\\s]+)\\n\\s+- https://[^/]+/[^/]+/[^/]+/releases/download/(?<currentValue>v[^/]+)/",
        "# renovate: datasource=github-releases depName=(?<depName>[^\\s]+)\\n\\s+- https://[^/]+/(?:[^/]+/){2}(?<currentValue>v[^/]+)/",
      ],
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      description: "Track Talos and Kubernetes versions in talconfig.yaml",
      managerFilePatterns: ["/talos/talconfig\\.yaml$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\n\\w+:\\s*(?<currentValue>v\\S+)",
      ],
    },
    {
      customType: "regex",
      description: "Track Talos and Kubernetes versions in Tuppr upgrade CRDs",
      managerFilePatterns: ["/kubernetes/infra/tuppr/upgrades/.*\\.ya?ml$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\n\\s+version:\\s*(?<currentValue>v\\S+)",
      ],
    },
  ],
}
