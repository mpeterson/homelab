{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      customType: "regex",
      description: "Track KSOPS version in ArgoCD repo-server patch",
      managerFilePatterns: [
        "/kubernetes/bootstrap/argocd/patches/argocd-repo-server-ksops\\.yaml$/",
      ],
      matchStrings: [
        "# renovate: datasource=github-releases depName=(?<depName>[^\\s]+)\\s+KSOPS_VERSION=\"(?<currentValue>v[^\"]+)\"",
      ],
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      description: "Track argocd-diff-preview Docker image in ArgoCD mod",
      managerFilePatterns: [
        "/kubernetes/bootstrap/argocd/mod\\.just$/",
      ],
      matchStrings: [
        "# renovate: datasource=docker depName=(?<depName>[^\\s]+)\\n_argocd_diff_preview_version := \"(?<currentValue>[^@\"]+)(?:@(?<currentDigest>sha256:[^\"]+))?\"",
      ],
      autoReplaceStringTemplate: "# renovate: datasource=docker depName={{{depName}}}\n_argocd_diff_preview_version := \"{{{newValue}}}@{{{newDigest}}}\"",
      datasourceTemplate: "docker",
    },
    {
      customType: "regex",
      description: "Track ArgoCD Helm chart version for diff preview",
      managerFilePatterns: [
        "/kubernetes/bootstrap/argocd/mod\\.just$/",
      ],
      matchStrings: [
        "# renovate: datasource=helm registryUrl=(?<registryUrl>[^\\s]+) depName=(?<depName>[^\\s]+)\\n_argocd_chart_version := \"(?<currentValue>[^\"]+)\"",
      ],
      datasourceTemplate: "helm",
    },
  ],
}
