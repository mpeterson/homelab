{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    ":disableRateLimiting",
    // Local modular configs
    "github>mpeterson/homelab//.renovate/autoMerge.json5",
    "github>mpeterson/homelab//.renovate/commitMessage.json5",
    "github>mpeterson/homelab//.renovate/groups.json5",
    "github>mpeterson/homelab//.renovate/customManagers.json5",
  ],
  timezone: "Asia/Jerusalem",
  schedule: ["after 2am and before 7am"],
  platformAutomerge: true,
  // Manager file patterns for Kubernetes manifests
  argocd: {
    managerFilePatterns: ["/^kubernetes/.+\\.ya?ml$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/^kubernetes/.+\\.ya?ml$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/^kubernetes/.+\\.ya?ml$/"],
  },
  "git-submodules": {
    enabled: true,
  },
  packageRules: [
    {
      description: "SOPS files: never automerge, label for manual re-encryption",
      matchFileNames: ["**/*.sops.yaml", "**/*.sops.yml"],
      automerge: false,
      labels: ["manual-review", "sops-reencrypt"],
    },
    {
      description: "Default: label all PRs for manual review",
      matchUpdateTypes: ["major", "minor", "patch", "digest", "pin", "pinDigest", "rollback", "bump"],
      labels: ["manual-review"],
    },
    {
      description: "Never automerge app-template Helm chart updates",
      matchPackageNames: ["app-template"],
      automerge: false,
    },
    {
      description: "Never automerge Cilium — CNI upgrade is high-risk",
      matchPackageNames: ["cilium"],
      automerge: false,
    },
    {
      description: "OCI Helm charts: disable digest pinning — version fields don't support digest format",
      matchPackageNames: [
        "ghcr.io/spegel-org/helm-charts/spegel",
        "ghcr.io/home-operations/charts/tuppr",
      ],
      pinDigests: false,
    },
    // --- Version coupling constraints ---
    // Only hard constraints that rarely change. For version-coupled
    // dependencies, we use prBodyNotes reminders instead of
    // allowedVersions to avoid stale caps.
    {
      description: "Helm pinned to 3.x — ArgoCD bundles Helm 3.19.4, Helm 4 is incompatible",
      matchDepNames: ["aqua:helm/helm"],
      allowedVersions: "<4",
    },
    {
      description: "Warn and block: Gateway API must match Cilium's supported version",
      matchPackageNames: ["cilium"],
      prBodyNotes: [
        "⚠️ **Coupled dependency**: Gateway API CRDs are grouped with this PR. Before merging, verify the new Cilium version's supported Gateway API version at the [Cilium Gateway API docs](https://docs.cilium.io/en/stable/network/servicemesh/gateway-api/gateway-api.html). Remove the `do-not-merge` label once verified.",
      ],
      labels: ["do-not-merge", "manual-review"],
    },
    {
      description: "Warn and block: check Talos support matrix for K8s and kubectl compatibility",
      matchDepNames: ["aqua:siderolabs/talos"],
      prBodyNotes: [
        "⚠️ **Coupled dependencies**: Before merging, check the [Talos support matrix](https://docs.siderolabs.com/talos/latest/getting-started/support-matrix/) for the new version's supported K8s range. Tuppr will also validate at runtime. Remove the `do-not-merge` label once verified.",
      ],
      labels: ["do-not-merge", "manual-review"],
    },
    {
      description: "Remind to check Helm/Kustomize bundled versions when ArgoCD upgrades",
      matchDepNames: ["aqua:argoproj/argo-cd"],
      prBodyNotes: [
        "⚠️ **Coupled dependency**: Kustomize and Helm are grouped with this PR. Before merging, verify ArgoCD's bundled Helm and Kustomize versions (`kubectl -n argocd exec deploy/argocd-repo-server -- helm version --short` / `kustomize version`) and update `allowedVersions` for `aqua:helm/helm` in `renovate.json5` if needed, then let Renovate rebase.",
      ],
    },
    {
      description: "Separate Talos installer minor/patch PRs for safe sequential upgrade paths",
      matchPackageNames: ["ghcr.io/siderolabs/installer"],
      separateMajorMinor: true,
      separateMinorPatch: true,
    },
    {
      description: "Separate talosctl minor/patch PRs to match installer branch naming",
      matchDepNames: ["aqua:siderolabs/talos"],
      separateMajorMinor: true,
      separateMinorPatch: true,
    },
    {
      description: "Separate K8s kubelet minor/patch PRs for safe sequential upgrade paths",
      matchPackageNames: ["ghcr.io/siderolabs/kubelet"],
      separateMajorMinor: true,
      separateMinorPatch: true,
    },
    {
      description: "Separate kubectl minor/patch PRs to match kubelet branch naming",
      matchDepNames: ["aqua:kubernetes/kubectl"],
      separateMajorMinor: true,
      separateMinorPatch: true,
    },
    {
      description: "Never automerge Talos or Kubernetes upgrades — require manual review",
      matchPackageNames: ["ghcr.io/siderolabs/installer", "ghcr.io/siderolabs/kubelet"],
      automerge: false,
      pinDigests: false,
      labels: ["manual-review"],
    },
    {
      description: "Warn and block: K8s upgrades need verification against Talos support matrix",
      matchPackageNames: ["ghcr.io/siderolabs/kubelet"],
      prBodyNotes: [
        "⚠️ **Coupled dependency**: Verify this K8s version is supported by the current Talos version at the [Talos support matrix](https://docs.siderolabs.com/talos/latest/getting-started/support-matrix/). Tuppr will also validate at runtime. Remove the `do-not-merge` label once verified.",
      ],
      labels: ["do-not-merge", "manual-review"],
    },
  ],
}
